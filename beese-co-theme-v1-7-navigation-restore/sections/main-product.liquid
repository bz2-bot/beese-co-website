<section class="page-width product-page" data-product-root>
  <div class="product-gallery" data-product-gallery>
    <div class="product-gallery__main">
      {% if product.featured_image %}
        {{ product.featured_image | image_url: width: 1800 | image_tag: loading: 'eager', data-main-image: '', alt: product.featured_image.alt | default: product.title }}
      {% else %}<img src="{{ 'placeholder-product.svg' | asset_url }}" class="theme-placeholder-image" alt="Product image placeholder" loading="eager">{% endif %}
    </div>
    {% if product.images.size > 1 %}<div class="product-thumbs" aria-label="Product images">
      {% for image in product.images %}<button class="product-thumb" type="button" data-thumb data-src="{{ image | image_url: width: 1800 }}" data-alt="{{ image.alt | default: product.title | escape }}" data-tags="{{ image.alt | escape }}" {% if forloop.first %}aria-current="true"{% endif %}>{{ image | image_url: width: 260 | image_tag: loading: 'lazy', alt: image.alt | default: product.title }}</button>{% endfor %}
    </div>{% endif %}
  </div>
  <div class="product-form-wrap">
    <div class="eyebrow">Made to order</div>
    <h1 class="heading heading-md">{{ product.title }}</h1>
    <div class="price" data-product-price>{{ product.selected_or_first_available_variant.price | money }}</div>
    <div>{{ product.description }}</div>
    {% form 'product', product, enctype: 'multipart/form-data', data-product-form: '' %}
      {% unless product.has_only_default_variant %}
        {% for option in product.options_with_values %}<fieldset class="field" data-option-position="{{ option.position }}"><legend>{{ option.name }}</legend><div class="choice-row">
          {% for value in option.values %}<div class="choice"><input type="radio" id="opt-{{ option.position }}-{{ forloop.index }}" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %}><label for="opt-{{ option.position }}-{{ forloop.index }}">{{ value }}</label></div>{% endfor %}
        </div></fieldset>{% endfor %}
      {% endunless %}
      {% if section.settings.show_decoration %}<fieldset class="field" data-decoration-choice><legend>Decoration Method</legend><div class="choice-row">
        <div class="choice"><input type="radio" id="dec-laser" name="properties[Decoration Method]" value="Laser Engraved" required checked><label for="dec-laser">Laser Engraved</label></div>
        {% unless section.settings.laser_only %}<div class="choice"><input type="radio" id="dec-full" name="properties[Decoration Method]" value="Full Color UV"><label for="dec-full">Full Color UV</label></div>{% endunless %}
      </div></fieldset>{% endif %}
      <div class="field"><label for="Personalization">Personalization</label><input id="Personalization" type="text" name="properties[Personalization]" placeholder="Add a name, monogram or text"></div>
      <div class="field"><label for="Phone">Phone Number for Proof</label><input id="Phone" type="tel" name="properties[Phone Number for Proof]" required placeholder="Please make sure this is correct"></div>
      <div class="field"><label for="Artwork">Upload Artwork</label><input id="Artwork" type="file" name="properties[Artwork Upload]"></div>
      <div class="field"><label for="Instructions">Special Instructions</label><textarea id="Instructions" name="properties[Special Instructions]" placeholder="Tell us anything we should know."></textarea></div>
      <div class="field proof-check"><input id="Proof" type="checkbox" name="properties[Digital Proof Agreement]" value="Agreed" required><label for="Proof">I understand I will receive a digital proof by text (please make sure my phone number is correct) before production begins. Production will not begin until I approve my proof.</label></div>
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-variant-id>
      <div class="qty-row"><input type="number" name="quantity" min="1" value="1" aria-label="Quantity"><button class="button" type="submit" data-add-button {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}><span data-add-label>{% if product.selected_or_first_available_variant.available %}Add to Cart{% else %}Sold Out{% endif %}</span></button></div>
    {% endform %}
    <div class="micro-trust"><div>Digital proof included</div><div>Made to order</div><div>Pickup or shipping</div></div>
  </div>
  <script type="application/json" data-product-json>{{ product | json }}</script>
</section>
{% schema %}{"name":"Main product","settings":[{"type":"checkbox","id":"show_decoration","label":"Show decoration method","default":true},{"type":"checkbox","id":"laser_only","label":"Laser only (use for handled tumblers)","default":false}]}{% endschema %}
