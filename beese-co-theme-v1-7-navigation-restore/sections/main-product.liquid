<section
  class="page-width product-page"
  data-product-root
  data-preview-profile="{{ section.settings.preview_profile }}"
  style="
    --preview-left: {{ section.settings.preview_left }}%;
    --preview-top: {{ section.settings.preview_top }}%;
    --preview-width: {{ section.settings.preview_width }}%;
    --preview-height: {{ section.settings.preview_height }}%;
  "
>
  <div class="product-gallery" data-product-gallery>
    <div class="product-gallery__stage" data-preview-stage>
      {% if product.featured_image %}
        {% assign featured_alt = product.featured_image.alt | default: product.title %}
        {{
          product.featured_image
          | image_url: width: 1800
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '600, 900, 1200, 1500, 1800',
            sizes: '(min-width: 901px) 55vw, 100vw',
            data-main-image: '',
            class: 'product-gallery__main',
            alt: featured_alt
        }}
      {% else %}
        <img src="{{ 'placeholder-product.svg' | asset_url }}" class="theme-placeholder-image product-gallery__main" alt="Product image placeholder" width="1800" height="1800" loading="eager">
      {% endif %}
      <div class="product-preview__boundary" data-preview-boundary aria-hidden="true">
        <img class="product-preview__artwork" data-artwork-preview alt="" width="576" height="1170">
      </div>
      <div class="product-preview__badge">Instant preview — taped proof required</div>
    </div>
    {% if product.images.size > 1 %}
      <div class="product-thumbs" aria-label="Product images">
        {% for image in product.images %}
          {% assign image_alt = image.alt | default: product.title %}
          <button class="product-thumb" type="button" data-thumb data-image-id="{{ image.id }}" data-src="{{ image | image_url: width: 1800 }}" data-alt="{{ image.alt | default: product.title | escape }}" data-tags="{{ image.alt | escape }}" aria-label="Show {{ image_alt | escape }}" {% if forloop.first %}aria-current="true"{% endif %}>
            {{ image | image_url: width: 260 | image_tag: loading: 'lazy', widths: '130, 195, 260', sizes: '84px', alt: image_alt }}
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="product-form-wrap">
    <div class="eyebrow">Made just for you</div>
    <h1 class="heading heading-md">{{ product.title }}</h1>
    <div class="price" data-product-price>{{ product.selected_or_first_available_variant.price | money }}</div>
    <p class="product-form-wrap__promise">Share what you have. We will help turn it into something made for you.</p>

    {% form 'product', product, enctype: 'multipart/form-data', data-product-form: '' %}
      {% unless product.has_only_default_variant %}
        {% for option in product.options_with_values %}
          <fieldset class="field" data-option-position="{{ option.position }}" data-option-name="{{ option.name | handleize }}">
            <legend>{{ option.name }}</legend>
            <div class="choice-row">
              {% for value in option.values %}
                <div class="choice">
                  <input type="radio" id="opt-{{ option.position }}-{{ forloop.index }}" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %}>
                  <label for="opt-{{ option.position }}-{{ forloop.index }}">{{ value }}</label>
                </div>
              {% endfor %}
            </div>
          </fieldset>
        {% endfor %}
      {% endunless %}

      {% if section.settings.show_decoration %}
        <fieldset class="field" data-decoration-choice>
          <legend>Choose how we make it</legend>
          <div class="choice-row">
            <div class="choice"><input type="radio" id="dec-laser" name="properties[Decoration Method]" value="Laser Engraved" required checked data-decoration-laser><label for="dec-laser">Laser Engraved</label></div>
            {% unless section.settings.laser_only %}<div class="choice"><input type="radio" id="dec-full" name="properties[Decoration Method]" value="Full Color UV" data-decoration-full-color><label for="dec-full">Full Color</label></div>{% endunless %}
          </div>
          <small class="field-help" data-decoration-help>Laser engraving previews your uploaded artwork in engraved gray.</small>
          <small class="field-help field-help--rule" data-decoration-rule aria-live="polite" hidden>Full wrap is available with laser engraving only.</small>
        </fieldset>
      {% endif %}

      <div class="field field--share-idea">
        <label for="Artwork">Share your idea</label>
        <p class="field-intro">Upload a logo, screenshot, sketch, Pinterest inspiration, existing artwork or anything else you have.</p>
        <input id="Artwork" type="file" name="properties[Artwork or Inspiration Upload]" accept=".png,.jpg,.jpeg,.pdf,.svg" data-artwork-upload aria-describedby="ArtworkHelp ArtworkStatus DesignRequirement">
        <small class="field-help" id="ArtworkHelp">Your file does not need to be production ready. Transparent PNG files create the best instant preview, and your original file stays attached to the order.</small>
        <small class="field-help" id="ArtworkStatus" data-artwork-status aria-live="polite"></small>
        <div class="preview-controls" data-preview-controls>
          <div class="preview-control"><label for="ArtworkSize"><span>Preview size</span><span data-size-value>64%</span></label><input id="ArtworkSize" type="range" min="20" max="92" value="64" data-preview-size></div>
          <div class="preview-control"><label for="ArtworkPosition"><span>Vertical position</span><span data-position-value>50%</span></label><input id="ArtworkPosition" type="range" min="15" max="85" value="50" data-preview-position></div>
        </div>
      </div>

      <div class="field"><label for="Personalization">Name, monogram or additional text</label><input id="Personalization" type="text" name="properties[Personalization]" maxlength="120" data-personalization placeholder="Leave blank if you only want your uploaded idea" aria-describedby="DesignRequirement"><small class="field-help" id="DesignRequirement">Provide an uploaded idea, personalization text or both so we know what to create.</small></div>
      <div class="field"><label for="Instructions">Tell us anything else</label><textarea id="Instructions" name="properties[Special Instructions]" maxlength="1000" placeholder="Placement, colors, style, what you like about the inspiration or anything else that will help us create it."></textarea></div>
      <div class="field"><label for="Phone">Mobile number for your taped proof</label><input id="Phone" type="tel" name="properties[Mobile Number for Taped Proof]" autocomplete="tel" inputmode="tel" minlength="10" required placeholder="Please make sure this number is correct"><small class="field-help">We use this number only to text your taped proof and communicate about this order.</small></div>

      <div class="proof-panel"><strong>Taped proof within 24 hours</strong><span>Your instant preview is only a starting point. We will text a photo of the final taped proof showing the actual size and placement before production begins.</span></div>
      <div class="field proof-check"><input id="Proof" type="checkbox" name="properties[Taped Proof Agreement]" value="Agreed" required><label for="Proof">I understand I will receive my taped proof by text within 24 hours. My order will not go into production until I approve it.</label></div>

      <input type="hidden" name="properties[Instant Preview Decoration]" value="Laser Engraved" data-preview-decoration>
      <input type="hidden" name="properties[Instant Preview Profile]" value="{{ section.settings.preview_profile }}" data-preview-profile-property>
      <input type="hidden" name="properties[Instant Preview Size]" value="64%" data-preview-size-property>
      <input type="hidden" name="properties[Instant Preview Position]" value="50%" data-preview-position-property>
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-variant-id>

      <div class="product-form-error" data-product-error role="alert"></div>
      <div class="qty-row"><input type="number" name="quantity" min="1" step="1" value="1" aria-label="Quantity"><button class="button" type="submit" data-add-button {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}><span data-add-label>{% if product.selected_or_first_available_variant.available %}Start My Custom Order{% else %}Sold Out{% endif %}</span></button></div>
    {% endform %}

    <div class="micro-trust"><div>Taped proof within 24 hours</div><div>Nothing is made until you approve it</div><div>Most orders are completed in 5–7 business days</div><div>Timing depends on in-house stock and order size</div><div>Local pickup or nationwide shipping</div></div>

    {% render 'beese-proof-process' %}

    {% if product.description != blank %}<div class="product-description"><h2>Product details</h2>{{ product.description }}</div>{% endif %}

    <nav class="product-related-links" aria-label="Related shopping links">{% if collection %}<a href="{{ collection.url }}">Shop more {{ collection.title }}</a>{% else %}<a href="{{ routes.root_url }}collections/tumblers">Shop all tumblers</a>{% endif %}<a href="{{ routes.root_url }}pages/contact">Questions? Contact Dana</a></nav>
  </div>

  <script type="application/json" data-product-json>{{ product | json }}</script>
</section>

<script>
  (() => {
    const root = document.currentScript.previousElementSibling;
    const form = root?.querySelector('[data-product-form]');
    if (!form) return;
    form.addEventListener('submit', (event) => {
      const artwork = form.querySelector('[data-artwork-upload]');
      const personalization = form.querySelector('[data-personalization]');
      const error = form.querySelector('[data-product-error]');
      if (artwork?.files?.length || personalization?.value.trim()) return;
      event.preventDefault();
      if (error) { error.textContent = 'Upload an idea or enter the name, monogram or text you want us to create.'; error.classList.add('is-visible'); }
      personalization?.focus();
    });
  })();
</script>

{% schema %}
{"name":"Main product","settings":[{"type":"checkbox","id":"show_decoration","label":"Show decoration method","default":true},{"type":"checkbox","id":"laser_only","label":"Laser only (use for handled tumblers)","default":false},{"type":"header","content":"Instant preview boundary"},{"type":"text","id":"preview_profile","label":"Preview profile name","default":"22 oz master"},{"type":"range","id":"preview_left","label":"Boundary left position","min":0,"max":70,"step":1,"unit":"%","default":34},{"type":"range","id":"preview_top","label":"Boundary top position","min":0,"max":70,"step":1,"unit":"%","default":16},{"type":"range","id":"preview_width","label":"Boundary width","min":10,"max":70,"step":1,"unit":"%","default":32},{"type":"range","id":"preview_height","label":"Boundary height","min":10,"max":80,"step":1,"unit":"%","default":65}]}
{% endschema %}