<section><div class="collection-hero"><div class="collection-hero__copy"><div class="eyebrow">{{ section.settings.eyebrow }}</div><h1 class="heading heading-lg">{{ section.settings.heading }}</h1><p>{{ section.settings.text }}</p></div><div class="collection-hero__media">{% if section.settings.hero_image != blank %}{{ section.settings.hero_image | image_url: width: 1600 | image_tag: loading: 'eager' }}{% else %}<img src="{{ 'placeholder-collection.svg' | asset_url }}" class="theme-placeholder-image" alt="Category hero image placeholder" loading="eager">{% endif %}</div></div><div class="page-width section"><div class="landing-grid">{% for block in section.blocks %}<a class="landing-card" href="{{ block.settings.link }}" {{ block.shopify_attributes }}><div class="landing-card__media">{% if block.settings.image != blank %}{{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}{% else %}<img src="{{ 'placeholder-category.svg' | asset_url }}" class="theme-placeholder-image" alt="Category card image placeholder" loading="lazy">{% endif %}</div><div class="landing-card__copy"><h2 class="heading heading-md">{{ block.settings.title }}</h2><p>{{ block.settings.text }}</p><span class="button">{{ block.settings.button }}</span></div></a>{% endfor %}</div></div></section>{% schema %}{"name":"Category landing","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Beese & Co."},{"type":"text","id":"heading","label":"Heading","default":"Shop the collection"},{"type":"textarea","id":"text","label":"Text","default":"Choose a product first, then make it yours."},{"type":"image_picker","id":"hero_image","label":"Hero image"}],"blocks":[{"type":"card","name":"Card","settings":[{"type":"text","id":"title","label":"Title","default":"Product Type"},{"type":"textarea","id":"text","label":"Text","default":"Personalized and made to order."},{"type":"text","id":"button","label":"Button label","default":"Shop Now"},{"type":"image_picker","id":"image","label":"Image"},{"type":"url","id":"link","label":"Link"}]}],"presets":[{"name":"Category landing","blocks":[{"type":"card"},{"type":"card"},{"type":"card"}]}]}{% endschema %}