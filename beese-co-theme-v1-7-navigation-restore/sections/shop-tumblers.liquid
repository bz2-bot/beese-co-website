<section class="section section--shop-tumblers">
  <div class="page-width">
    <div class="section-title">
      <h2 class="heading heading-md">{{ section.settings.heading }}</h2>
    </div>

    <div class="shopping-path-grid">
      <a class="shopping-path shopping-path--custom" href="{{ section.settings.custom_link | default: '#' }}">
        <div class="shopping-path__copy">
          <div class="eyebrow">{{ section.settings.custom_eyebrow }}</div>
          <h3 class="heading heading-md">{{ section.settings.custom_heading }}</h3>
          <p>{{ section.settings.custom_text }}</p>
          <span class="button">{{ section.settings.custom_label }} <span aria-hidden="true">→</span></span>
        </div>
        <div class="shopping-path__media">
          {% if section.settings.custom_image != blank %}
            {{ section.settings.custom_image | image_url: width: 1000 | image_tag: loading: 'lazy', widths: '500, 750, 1000', sizes: '(min-width: 990px) 33vw, 100vw' }}
          {% else %}
            <img src="{{ 'placeholder-product.svg' | asset_url }}" class="theme-placeholder-image" alt="Replace fully custom tumbler photo" loading="lazy">
          {% endif %}
        </div>
      </a>

      <a class="shopping-path" href="{{ section.settings.ready_link | default: '#' }}">
        <div class="shopping-path__copy">
          <div class="eyebrow">{{ section.settings.ready_eyebrow }}</div>
          <h3 class="heading heading-md">{{ section.settings.ready_heading }}</h3>
          <p>{{ section.settings.ready_text }}</p>
          <span class="button button--secondary">{{ section.settings.ready_label }} <span aria-hidden="true">→</span></span>
        </div>
        <div class="shopping-path__media">
          {% if section.settings.ready_image != blank %}
            {{ section.settings.ready_image | image_url: width: 1000 | image_tag: loading: 'lazy', widths: '500, 750, 1000', sizes: '(min-width: 990px) 33vw, 100vw' }}
          {% else %}
            <img src="{{ 'placeholder-collection.svg' | asset_url }}" class="theme-placeholder-image" alt="Replace ready-to-buy tumbler collection photo" loading="lazy">
          {% endif %}
        </div>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name":"Shop tumblers paths",
  "settings":[
    {"type":"text","id":"heading","label":"Heading","default":"Shop Tumblers"},
    {"type":"text","id":"custom_eyebrow","label":"Custom eyebrow","default":"Create something unique"},
    {"type":"text","id":"custom_heading","label":"Custom heading","default":"Fully Custom Tumblers"},
    {"type":"textarea","id":"custom_text","label":"Custom description","default":"Upload artwork, add names, business logos, wedding gifts and more."},
    {"type":"text","id":"custom_label","label":"Custom button","default":"Start custom order"},
    {"type":"url","id":"custom_link","label":"Custom link"},
    {"type":"image_picker","id":"custom_image","label":"Custom image"},
    {"type":"text","id":"ready_eyebrow","label":"Ready-to-buy eyebrow","default":"Ready to buy"},
    {"type":"text","id":"ready_heading","label":"Ready-to-buy heading","default":"Explore Ready-to-Buy Designs"},
    {"type":"textarea","id":"ready_text","label":"Ready-to-buy description","default":"Find the perfect design for every season, style and occasion."},
    {"type":"text","id":"ready_label","label":"Ready-to-buy button","default":"Browse designs"},
    {"type":"url","id":"ready_link","label":"Ready-to-buy link"},
    {"type":"image_picker","id":"ready_image","label":"Ready-to-buy image"}
  ],
  "presets":[{"name":"Shop tumblers paths"}]
}
{% endschema %}
