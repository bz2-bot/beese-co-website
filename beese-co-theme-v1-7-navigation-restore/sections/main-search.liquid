<section class="page-width section"><h1 class="heading heading-lg">Search</h1><form action="{{ routes.search_url }}"><input type="search" name="q" value="{{ search.terms | escape }}" style="padding:14px;border:1px solid var(--line);width:min(600px,100%)"><button class="button">Search</button></form>{% if search.performed %}<div class="collection-grid" style="margin-top:30px">{% for item in search.results %}{% if item.object_type == 'product' %}{% render 'product-card', product: item %}{% endif %}{% endfor %}</div>{% endif %}</section>{% schema %}{"name":"Main search","settings":[]}{% endschema %}