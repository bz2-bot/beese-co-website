<section class="page-width section"><h1 class="heading heading-lg">Cart</h1>{% if cart.item_count == 0 %}<p>Your cart is empty.</p>{% else %}<form action="{{ routes.cart_url }}" method="post">{% for item in cart.items %}<div style="display:grid;grid-template-columns:100px 1fr auto;gap:16px;padding:18px 0;border-bottom:1px solid var(--line)">{% if item.image %}{{ item.image | image_url: width: 200 | image_tag }}{% endif %}<div><strong>{{ item.product.title }}</strong><div>{{ item.variant.title }}</div>{% for p in item.properties %}{% unless p.last == blank %}<small>{{ p.first }}: {{ p.last }}</small><br>{% endunless %}{% endfor %}</div><div>{{ item.final_line_price | money }}</div></div>{% endfor %}<button class="button" type="submit" name="checkout">Checkout</button></form>{% endif %}</section>{% schema %}{"name":"Main cart","settings":[]}{% endschema %}