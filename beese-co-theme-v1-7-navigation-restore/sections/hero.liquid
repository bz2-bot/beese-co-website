<section class="hero"><div class="hero__grid"><div class="hero__content"><div class="eyebrow">{{ section.settings.eyebrow }}</div><h1 class="heading heading-xl">{{ section.settings.heading }}</h1><div class="script">{{ section.settings.script }}</div><p>{{ section.settings.text }}</p><div class="hero__actions"><a class="button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a><a class="button button--secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a></div></div><div class="hero__media">{% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'eager', widths: '700,1000,1400,1800' }}{% else %}<img src="{{ 'placeholder-hero.svg' | asset_url }}" class="theme-placeholder-image" alt="Placeholder for the approved Beese and Co. hero photograph" loading="eager">{% endif %}</div></div></section>{% schema %}{"name":"Hero","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Custom made in Illinois"},{"type":"textarea","id":"heading","label":"Heading","default":"Custom Laser Engraving & UV Printing"},{"type":"text","id":"script","label":"Script line","default":"Made one piece at a time."},{"type":"textarea","id":"text","label":"Text","default":"Personalized drinkware, ornaments, gifts and custom orders."},{"type":"text","id":"primary_label","label":"Primary button","default":"Shop Tumblers"},{"type":"url","id":"primary_link","label":"Primary link"},{"type":"text","id":"secondary_label","label":"Secondary button","default":"Bulk Orders"},{"type":"url","id":"secondary_link","label":"Secondary link"},{"type":"image_picker","id":"image","label":"Hero image"}],"presets":[{"name":"Hero"}]}{% endschema %}