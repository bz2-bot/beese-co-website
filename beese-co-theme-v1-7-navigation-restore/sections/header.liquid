<header class="site-header site-header--retail" data-site-header>
  <div class="site-header__brand-row">
    <div class="page-width site-header__top">
      <a class="site-logo{% if section.settings.invert_logo %} site-logo--invert{% endif %}" href="{{ routes.root_url }}" aria-label="{{ shop.name }} home">
        {% if section.settings.logo != blank %}
          {{ section.settings.logo | image_url: width: 520 | image_tag: widths: '240,360,520', alt: shop.name, loading: 'eager' }}
        {% else %}
          <span class="site-logo__wordmark">BEESE &amp; CO.</span>
          <small>LASER ENGRAVING &amp; UV PRINTING</small>
        {% endif %}
      </a>

      <div class="header-icons" aria-label="Store tools">
        <a class="header-icon" href="{{ routes.search_url }}" aria-label="Search">
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.7" cy="10.7" r="6.7"></circle><path d="m16 16 5 5"></path></svg>
        </a>
        <a class="header-icon header-icon--cart" href="{{ routes.cart_url }}" aria-label="Cart with {{ cart.item_count }} items">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 8h14l-1 13H6L5 8Z"></path><path d="M8 8V6a4 4 0 0 1 8 0v2"></path></svg>
          <span class="header-icon__count">{{ cart.item_count }}</span>
        </a>
        <a class="header-icon header-icon--account" href="{{ routes.account_url }}" aria-label="Account">
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="7.5" r="4"></circle><path d="M4.5 22a7.5 7.5 0 0 1 15 0"></path></svg>
        </a>
        <button class="header-icon header-menu-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="MobileMenu" data-mobile-toggle>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"></path></svg>
        </button>
      </div>
    </div>
  </div>

  {% if section.settings.guide_text != blank %}
    <a class="header-guide" href="{{ section.settings.guide_link | default: section.settings.contact_link | default: routes.root_url }}">
      <span>{{ section.settings.guide_text }}</span>
      {% if section.settings.guide_cta != blank %}<strong>{{ section.settings.guide_cta }}</strong>{% endif %}
    </a>
  {% endif %}

  <nav class="category-nav" aria-label="Shop categories">
    <div class="page-width category-nav__scroller">
      <a class="category-nav__item{% if request.path contains '/collections/tumblers' or template.suffix == 'tumblers' %} is-active{% endif %}" href="{{ section.settings.tumblers_link | default: routes.root_url }}">Tumblers</a>
      <a class="category-nav__item{% if request.path contains '/collections/ornaments' or template.suffix == 'ornaments' %} is-active{% endif %}" href="{{ section.settings.ornaments_link | default: routes.root_url }}">Ornaments</a>
      <a class="category-nav__item" href="{{ section.settings.golf_link | default: routes.root_url }}">Golf Balls &amp; More</a>
      <a class="category-nav__item" href="{{ section.settings.custom_link | default: routes.root_url }}">Custom Orders</a>
      <a class="category-nav__item" href="{{ section.settings.bulk_link | default: routes.root_url }}">Bulk Orders</a>
      <a class="category-nav__item" href="{{ section.settings.about_link | default: routes.root_url }}">About</a>
      <a class="category-nav__item" href="{{ section.settings.contact_link | default: routes.root_url }}">Contact</a>
    </div>
  </nav>

  <div class="mobile-menu" id="MobileMenu" data-mobile-menu>
    <div class="page-width mobile-menu__inner">
      <div class="mobile-menu__heading">Menu</div>
      <ul class="mobile-menu__list">
        <li><a href="{{ section.settings.tumblers_link | default: routes.root_url }}">Tumblers</a></li>
        <li><a href="{{ section.settings.ornaments_link | default: routes.root_url }}">Ornaments</a></li>
        <li><a href="{{ section.settings.golf_link | default: routes.root_url }}">Golf Balls &amp; More</a></li>
        <li><a href="{{ section.settings.custom_link | default: routes.root_url }}">Custom Orders</a></li>
        <li><a href="{{ section.settings.bulk_link | default: routes.root_url }}">Bulk Orders</a></li>
        <li><a href="{{ section.settings.about_link | default: routes.root_url }}">About</a></li>
        <li><a href="{{ section.settings.contact_link | default: routes.root_url }}">Contact</a></li>
      </ul>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {"type":"image_picker","id":"logo","label":"Logo"},
    {"type":"checkbox","id":"invert_logo","label":"Make uploaded logo white","default":true},
    {"type":"link_list","id":"menu","label":"Menu drawer","default":"main-menu"},
    {"type":"url","id":"tumblers_link","label":"Tumblers link"},
    {"type":"url","id":"ornaments_link","label":"Ornaments link"},
    {"type":"url","id":"golf_link","label":"Golf Balls & More link"},
    {"type":"url","id":"custom_link","label":"Custom Orders link"},
    {"type":"url","id":"bulk_link","label":"Bulk Orders link"},
    {"type":"url","id":"about_link","label":"About link"},
    {"type":"url","id":"contact_link","label":"Contact link"},
    {"type":"text","id":"guide_text","label":"Guide bar text","default":"Not sure where to start?"},
    {"type":"text","id":"guide_cta","label":"Guide bar link text","default":"Let us guide you"},
    {"type":"url","id":"guide_link","label":"Guide bar link"}
  ]
}
{% endschema %}