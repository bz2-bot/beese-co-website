<section class="section"><div class="page-width story"><div class="story__copy"><div class="eyebrow">{{ section.settings.eyebrow }}</div><h2 class="heading heading-lg">{{ section.settings.heading }}</h2><p>{{ section.settings.text }}</p><a class="button" href="{{ section.settings.link }}">{{ section.settings.label }}</a></div><div class="story__media">{% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}{% else %}<img src="{{ 'placeholder-story.svg' | asset_url }}" class="theme-placeholder-image" alt="Workshop or maker image placeholder" loading="lazy">{% endif %}</div></div></section>{% schema %}{"name":"Story","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Our Story"},{"type":"text","id":"heading","label":"Heading","default":"Made with care, one order at a time."},{"type":"richtext","id":"text","label":"Text","default":"<p>Beese & Co. creates personalized products that feel thoughtful, useful and made to last.</p>"},{"type":"text","id":"label","label":"Button","default":"Our Story"},{"type":"url","id":"link","label":"Link"},{"type":"image_picker","id":"image","label":"Image"}],"presets":[{"name":"Story"}]}{% endschema %}