<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#111111">
  <link rel="canonical" href="{{ canonical_url }}">

  <title>{% if page_title %}{{ page_title }}{% else %}{{ shop.name }}{% endif %}{% unless page_title contains shop.name %} — {{ shop.name }}{% endunless %}</title>

  {% assign seo_description = page_description | default: shop.description | strip_html | strip %}
  {% if seo_description != blank %}<meta name="description" content="{{ seo_description | escape }}">{% endif %}

  <meta property="og:site_name" content="{{ shop.name | escape }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | default: shop.name | escape }}">
  {% if seo_description != blank %}<meta property="og:description" content="{{ seo_description | escape }}">{% endif %}
  <meta property="og:type" content="{% if request.page_type == 'product' %}product{% else %}website{% endif %}">
  {% if page_image %}
    <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
    <meta property="og:image:width" content="1200">
  {% endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title | default: shop.name | escape }}">
  {% if seo_description != blank %}<meta name="twitter:description" content="{{ seo_description | escape }}">{% endif %}

  {% if request.page_type == 'index' %}
    {% capture structured_search_url %}{{ shop.url }}{{ routes.search_url }}?q={% raw %}{search_term_string}{% endraw %}{% endcapture %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": {{ shop.name | json }},
        "url": {{ shop.url | append: routes.root_url | json }}
        {% if settings.logo != blank %},"logo": {{ settings.logo | image_url: width: 600 | prepend: 'https:' | json }}{% endif %}
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": {{ shop.name | json }},
        "url": {{ shop.url | append: routes.root_url | json }},
        "potentialAction": {
          "@type": "SearchAction",
          "target": {{ structured_search_url | json }},
          "query-input": "required name=search_term_string"
        }
      }
    </script>
  {% elsif request.page_type == 'product' or request.page_type == 'collection' or request.page_type == 'page' %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": {{ shop.url | append: routes.root_url | json }}
          }
          {% if request.page_type == 'product' and collection %},
          {
            "@type": "ListItem",
            "position": 2,
            "name": {{ collection.title | json }},
            "item": {{ shop.url | append: collection.url | json }}
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ product.title | json }},
            "item": {{ canonical_url | json }}
          }
          {% else %},
          {
            "@type": "ListItem",
            "position": 2,
            "name": {{ page_title | json }},
            "item": {{ canonical_url | json }}
          }
          {% endif %}
        ]
      }
    </script>
  {% endif %}

  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ 'homepage-production.css' | asset_url | stylesheet_tag }}
  {{ 'tumbler-production.css' | asset_url | stylesheet_tag }}
  {{ 'product-production.css' | asset_url | stylesheet_tag }}
  {{ 'mobile-product-hotfix.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</head>
<body>
  <a class="skip-link" href="#MainContent">Skip to content</a>
  {% sections 'header-group' %}
  {% render 'breadcrumbs' %}
  <main id="MainContent" role="main">{{ content_for_layout }}</main>
  {% sections 'footer-group' %}
</body>
</html>