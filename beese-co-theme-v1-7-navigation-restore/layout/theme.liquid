<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#111111">
  <link rel="canonical" href="{{ canonical_url }}">

  {% assign seo_title = page_title | default: shop.name %}
  <title>{{ seo_title }}{% unless seo_title contains shop.name %} — {{ shop.name }}{% endunless %}</title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% elsif request.page_type == 'index' %}
    <meta name="description" content="Personalized tumblers, ornaments, golf gifts and custom laser engraving or full-color printing, made with care by Beese & Co. in Northern Illinois.">
  {% endif %}

  <meta property="og:site_name" content="{{ shop.name | escape }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ seo_title | escape }}">
  <meta property="og:type" content="{% if request.page_type == 'product' %}product{% else %}website{% endif %}">
  {% if page_description %}<meta property="og:description" content="{{ page_description | escape }}">{% endif %}
  {% if page_image %}<meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">{% endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ seo_title | escape }}">
  {% if page_description %}<meta name="twitter:description" content="{{ page_description | escape }}">{% endif %}

  {% if request.page_type == 'index' %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            "@id": {{ shop.url | append: '#organization' | json }},
            "name": {{ shop.name | json }},
            "url": {{ shop.url | json }}
          },
          {
            "@type": "WebSite",
            "@id": {{ shop.url | append: '#website' | json }},
            "url": {{ shop.url | json }},
            "name": {{ shop.name | json }},
            "publisher": {"@id": {{ shop.url | append: '#organization' | json }}}
          }
        ]
      }
    </script>
  {% endif %}

  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ 'production.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
  <script src="{{ 'production.js' | asset_url }}" defer></script>
</head>
<body>
  <a class="skip-link" href="#MainContent">Skip to content</a>
  {% sections 'header-group' %}
  <main id="MainContent" role="main">{{ content_for_layout }}</main>
  {% sections 'footer-group' %}
</body>
</html>