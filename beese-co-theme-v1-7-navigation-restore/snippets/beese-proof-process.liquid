<section class="beese-process" aria-labelledby="beese-process-{{ section.id }}">
  <div class="beese-process__header">
    <p class="eyebrow">What happens next</p>
    <h2 id="beese-process-{{ section.id }}">Your custom order, made simple</h2>
  </div>

  <ol class="beese-process__steps">
    <li>
      <span class="beese-process__number">1</span>
      <div>
        <strong>Share your idea</strong>
        <p>Upload a logo, screenshot, sketch, inspiration photo or anything else you have.</p>
      </div>
    </li>
    <li>
      <span class="beese-process__number">2</span>
      <div>
        <strong>Proof within 24 hours</strong>
        <p>We will text your taped proof for approval before anything is printed or engraved.</p>
      </div>
    </li>
    <li>
      <span class="beese-process__number">3</span>
      <div>
        <strong>You approve it</strong>
        <p>Production begins only after you approve the final size and placement.</p>
      </div>
    </li>
    <li>
      <span class="beese-process__number">4</span>
      <div>
        <strong>Production</strong>
        <p>Most orders are completed within 5–7 business days, depending on in-house stock and order size.</p>
      </div>
    </li>
    <li>
      <span class="beese-process__number">5</span>
      <div>
        <strong>Pickup or shipping</strong>
        <p>We will text you when your order is ready for pickup or send tracking when it ships.</p>
      </div>
    </li>
  </ol>
</section>