<a class="product-card" href="{{ product.url }}"><div class="product-card__media">{% if product.featured_image %}{{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy' }}{% else %}<img src="{{ 'placeholder-product.svg' | asset_url }}" class="theme-placeholder-image" alt="Product image placeholder" loading="lazy">{% endif %}</div><div class="product-card__info"><div class="product-card__title">{{ product.title }}</div><div class="product-card__price">{{ product.price | money }}</div></div></a>