{% unless request.page_type == 'index' or request.page_type == 'cart' or request.page_type == 'search' %}
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <div class="page-width">
      <ol class="breadcrumbs__list">
        <li><a href="{{ routes.root_url }}">Home</a></li>
        <li class="breadcrumbs__separator" aria-hidden="true">/</li>

        {% case request.page_type %}
          {% when 'product' %}
            {% if collection %}
              <li><a href="{{ collection.url }}">{{ collection.title }}</a></li>
              <li class="breadcrumbs__separator" aria-hidden="true">/</li>
            {% endif %}
            <li aria-current="page">{{ product.title }}</li>
          {% when 'collection' %}
            <li aria-current="page">{{ collection.title }}</li>
          {% when 'page' %}
            <li aria-current="page">{{ page.title }}</li>
          {% when 'blog' %}
            <li aria-current="page">{{ blog.title }}</li>
          {% when 'article' %}
            <li><a href="{{ blog.url }}">{{ blog.title }}</a></li>
            <li class="breadcrumbs__separator" aria-hidden="true">/</li>
            <li aria-current="page">{{ article.title }}</li>
          {% else %}
            <li aria-current="page">{{ page_title }}</li>
        {% endcase %}
      </ol>
    </div>
  </nav>
{% endunless %}
